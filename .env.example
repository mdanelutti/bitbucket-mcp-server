# Bitbucket Cloud credentials
BITBUCKET_USERNAME=your-email@example.com
BITBUCKET_API_TOKEN=ATATT...your-scoped-api-token

# Optional: default workspace (avoids passing it in every tool call)
BITBUCKET_WORKSPACE=your-workspace

# Enable destructive operations (merge, decline)
# BITBUCKET_ENABLE_DANGEROUS=true

# Transport mode: stdio (default) or http
# TRANSPORT=stdio

# HTTP server port (only used when TRANSPORT=http)
# PORT=3000
